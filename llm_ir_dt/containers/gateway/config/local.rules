
# ICMP detection
# 检测 ICMP 流量，比如 ping, 通常用于最基础的连通性探测告警
alert icmp any any -> $HOME_NET any (msg:"ICMP traffic detected"; sid:1000001; rev:1;)

# SSH brute-force detection (threshold: 5 attempts in 60 seconds)
#  - 针对 22 端口的 SSH 爆破迹象   - 同一源地址 60 秒内达到 5 次连接尝试就触发, 这是个很典型的“弱口令攻击”实验规则
alert tcp any any -> $HOME_NET 22 (msg:"Potential SSH brute force attack"; flags:S; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000002; rev:1;)

# SMB traffic to Samba server
#  专门监测到 Samba 服务器的 SMB/NetBIOS 流量。                                                                         
#  因为 10.0.2.12 是脆弱 Samba 主机，研究重点是它的相关访问
alert tcp any any -> 10.0.2.12 445 (msg:"SMB traffic to Samba server"; sid:1000003; rev:1;)
alert tcp any any -> 10.0.2.12 139 (msg:"SMB traffic to Samba server (NetBIOS)"; sid:1000004; rev:1;)

# Shellshock detection (look for () { pattern in HTTP headers)
#     - 这是 Shellshock 特征规则。                                                                                                                       
#     - 如果 HTTP 流量里出现 () { 这样的内容，就认为是 Shellshock 尝试。                                                                                 
#     - 这条规则比较粗糙，但很符合教学/实验环境用途
alert tcp any any -> $HOME_NET 80 (msg:"Shellshock attack attempt"; content:"() {"; sid:1000005; rev:1;)

# General HTTP traffic
#     - 只要有去 80 端口的 TCP SYN，就报 HTTP 流量。                                                                                                     
#     - 属于非常宽泛的流量可见性规则
alert tcp any any -> $HOME_NET 80 (msg:"HTTP traffic detected"; flags:S; sid:1000006; rev:1;)

# SSH connection attempts
#      - 只要有去 22 端口的 TCP SYN，就报 SSH 连接尝试。                                                                                                  
#      - 用于把“所有 SSH 接触”都记录下来
alert tcp any any -> $HOME_NET 22 (msg:"SSH connection attempt"; flags:S; sid:1000007; rev:1;)
